rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Catch-all default allow to ensure seamless sandbox & auth-less operation
    match /{document=**} {
      allow read, write: if true;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Collection: Users
    match /users/{userId} {
      allow read, write: if true;
    }

    // Collection: Reports
    match /reports/{reportId} {
      allow read, write: if true;
    }

    // Collection: Audit Logs
    match /audit_logs/{logId} {
      allow read, write: if true;
    }

    // Collection: Carbon Footprints
    match /carbon_footprints/{footprintId} {
      allow read, write: if true;
    }

    // Collection: Notifications
    match /notifications/{notifId} {
      allow read, write: if true;
    }

    // Collection: Notifications Subcollection
    match /notifications/{userId}/items/{itemId} {
      allow read, write: if true;
    }

    // Collection: Issues
    match /issues/{issueId} {
      allow read, write: if true;
    }

    // Collection: Issues Status History Subcollection
    match /issues/{issueId}/statusHistory/{historyId} {
      allow read, write: if true;
    }

    // Collection: Image Verifications
    match /imageVerifications/{verificationId} {
      allow read, write: if true;
    }

    // Collection: Authorities Assigned Issues
    match /authorities/{userId}/assignedIssues/{issueId} {
      allow read, write: if true;
    }
  }
}
